{
  "schemaVersion": 1,
  "id": "anduril",
  "version": "${version}",

  "name": "Andúril",
  "description": "Companion mod that bridges the Middle-earth server's in-game state to its website and Discord bot. HTTP API, daily-tick, audit logging.",
  "authors": [
    "SWMann"
  ],
  "contact": {
    "homepage": "https://middle-earth-website.vercel.app",
    "sources": "https://github.com/SWMann/Middle-Earth-Website"
  },

  "license": "All Rights Reserved",
  "icon": "assets/anduril/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "org.middleearth.anduril.Anduril"
    ],
    "server": [
      "org.middleearth.anduril.AndurilServer"
    ]
  },

  "depends": {
    "fabricloader": ">=0.16.7",
    "minecraft": "~1.21",
    "java": ">=21",
    "fabric-api": "*"
  },

  "suggests": {
    "me": "*"
  }
}
