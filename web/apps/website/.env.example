# Copy to .env.local and fill in. Never commit .env.local.

# Postgres. Neon connection string in production; local Postgres in dev.
DATABASE_URL=postgres://user:password@localhost:5432/middle_earth_web

# NextAuth. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Discord OAuth credentials. Create at https://discord.com/developers/applications
# Redirect URI: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Public origin. Used by NextAuth and for absolute URLs.
AUTH_URL=http://localhost:3000

# Mod HTTP API. Leave MOD_API_URL blank (or set MOD_API_MOCK=1) to use the
# in-process mock during Phase 1 development.
MOD_API_URL=
MOD_API_TOKEN=
MOD_API_MOCK=1
