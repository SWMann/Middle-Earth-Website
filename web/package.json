{
  "name": "middle-earth-web",
  "private": true,
  "version": "0.1.0",
  "description": "Website for the Middle-earth modded server.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @middle-earth/website run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
